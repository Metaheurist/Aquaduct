# Secrets / env files (never commit tokens)
.env
.env.*
!.env.example
*.token
*.secret
hf_token.txt

# Python
__pycache__/
*.py[cod]
*.pyd
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Virtual environments
.venv/
venv/
ENV/
.venv-build/

# Build / artifacts
dist/
*.egg-info/

# PyInstaller build work dir (generated)
build/aquaduct*/
build/ai-news-factory*/

# Hugging Face caches (often contain large blobs + auth state)
**/.cache/huggingface/
**/.cache/torch/
**/.cache/pip/

# Local model downloads can be huge; never commit them
models/

# Local app state (do not commit)
.Aquaduct_data/
# Legacy paths (before .Aquaduct_data); keep ignored if leftover from older builds
ui_settings.json
data/upload_tasks.json
data/characters.json
data/model_integrity_status.json
data/news_cache/seen.json
data/news_cache/seen_titles.json
data/news_cache/seen_*.json
data/news_cache/seen_titles_*.json

# Firecrawl CLI output (search/scrape artifacts; may include large JSON)
.firecrawl/

# Generated pipeline outputs (local)
runs/

# Repo-root cache / build logs (local)
.cache/
build/last-build.log
build/exe-smoke-*.txt
