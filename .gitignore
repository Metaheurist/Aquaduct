# Secrets / env files (never commit tokens)
.env
.env.*
!.env.example
*.token
*.secret
hf_token.txt

# Python
__pycache__/
*.py[cod]
*.pyd
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Virtual environments
.venv/
venv/
ENV/
.venv-build/

# Build / artifacts
dist/
*.egg-info/

# PyInstaller build work dir (generated)
build/ai-news-factory*/

# Hugging Face caches (often contain large blobs + auth state)
**/.cache/huggingface/
**/.cache/torch/
**/.cache/pip/

# Local model downloads can be huge; never commit them
models/
